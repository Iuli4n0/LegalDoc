@page "/documents"
@page "/documents/{Id:guid}"
@rendermode InteractiveServer
@using LegalDoc.Frontend.Models
@using LegalDoc.Frontend.Services
@inject ApiClient ApiClient
@inject ISnackbar Snackbar
@inject AuthService AuthService
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject IJSRuntime JS

<PageTitle>Document Details</PageTitle>

@if (!_authReady)
{
    <MudPaper Class="pa-4 mb-4" Elevation="0">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Class="mr-2"/>
        <MudText Typo="Typo.body1">Initializing session...</MudText>
    </MudPaper>
}

<MudText Typo="Typo.h4" GutterBottom="true">Search Document</MudText>

<MudCard Class="mb-4">
    <MudCardContent>
        <MudTextField @bind-Value="_searchId"
                      Label="Document ID (GUID)"
                      Placeholder="e.g. 3fa85f64-5717-4562-b3fc-2c963f66afa6"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.End"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      OnAdornmentClick="SearchDocument"
                      Disabled="@(!_authReady || _loading)"
                      Immediate="true"
                      OnKeyDown="OnSearchKeyDown"/>
    </MudCardContent>
    <MudCardActions>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="SearchDocument"
                   Disabled="@(_loading || !_authReady)"
                   StartIcon="@Icons.Material.Filled.Search">
            @if (_loading)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                <MudText Class="ms-2">Searching...</MudText>
            }
            else
            {
                <MudText>Search</MudText>
            }
        </MudButton>
    </MudCardActions>
</MudCard>

@if (_notFound)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">
        Document not found.
    </MudAlert>
}

@if (_document is not null)
{
    <MudCard Class="mb-4">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.Description" Class="mr-2"/>
                    @_document.FileName
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudSimpleTable Dense="true" Hover="true">
                <tbody>
                    <tr><td><strong>ID</strong></td><td>@_document.Id</td></tr>
                    <tr><td><strong>File Name</strong></td><td>@_document.FileName</td></tr>
                    <tr><td><strong>Content Type</strong></td><td>@_document.ContentType</td></tr>
                    <tr><td><strong>Size</strong></td><td>@FormatFileSize(_document.FileSize)</td></tr>
                    <tr><td><strong>Upload Date</strong></td><td>@_document.UploadedAt.ToString("dd.MM.yyyy HH:mm")</td></tr>
                </tbody>
            </MudSimpleTable>
        </MudCardContent>
    </MudCard>

    <MudCard Class="mb-4">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.Summarize" Class="mr-2"/>
                    Summary
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            @if (!string.IsNullOrEmpty(_document.Resume))
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                    Generated at: @_document.ResumeGeneratedAt?.ToString("dd.MM.yyyy HH:mm")
                </MudAlert>
                <MudText Typo="Typo.body1" Style="white-space: pre-wrap;">@_document.Resume</MudText>
            }
            else if (_generatingResume)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2"/>
                <MudText>Generating summary... This may take a few minutes.</MudText>
            }
            else
            {
                <MudText Color="Color.Secondary">No summary generated yet.</MudText>
            }
        </MudCardContent>
        <MudCardActions>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Secondary"
                       OnClick="GenerateResume"
                       Disabled="@(_generatingResume || !_authReady)"
                       StartIcon="@Icons.Material.Filled.AutoAwesome">
                @if (_generatingResume)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                    <MudText Class="ms-2">Generating...</MudText>
                }
                else
                {
                    <MudText>Generate Summary</MudText>
                }
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Info"
                       OnClick="DownloadDocument"
                       Disabled="@(!_authReady || _downloading)"
                       StartIcon="@Icons.Material.Filled.Download"
                       Class="ml-2">
                @if (_downloading)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                    <MudText Class="ms-2">Downloading...</MudText>
                }
                else
                {
                    <MudText>Download Document</MudText>
                }
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Error"
                       OnClick="ConfirmDeleteDocument"
                       Disabled="@(!_authReady || _deleting)"
                       StartIcon="@Icons.Material.Filled.DeleteForever"
                       Class="ml-2">
                Delete Document
            </MudButton>
        </MudCardActions>
    </MudCard>
}

@code {
    [Parameter]
    public Guid? Id { get; set; }

    private string _searchId = string.Empty;
    private bool _loading;
    private bool _notFound;
    private bool _generatingResume;
    private bool _deleting;
    private bool _downloading;
    private bool _authReady;
    private Guid? _pendingDocumentId;
    private GetDocumentResponse? _document;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login", forceLoad: false);
            return;
        }

        _authReady = true;

        if (_pendingDocumentId.HasValue)
        {
            await LoadDocument(_pendingDocumentId.Value);
            _pendingDocumentId = null;
        }

        StateHasChanged();
    }

    protected override Task OnParametersSetAsync()
    {
        if (Id.HasValue)
        {
            _searchId = Id.Value.ToString();

            if (_authReady)
            {
                return LoadDocument(Id.Value);
            }
            else
            {
                _pendingDocumentId = Id.Value;
            }
        }

        return Task.CompletedTask;
    }

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchDocument();
        }
    }

    private async Task SearchDocument()
    {
        if (!_authReady || !AuthState.IsAuthenticated)
            return;

        if (!Guid.TryParse(_searchId, out var id))
        {
            Snackbar.Add("Please enter a valid GUID.", Severity.Warning);
            return;
        }

        await LoadDocument(id);
    }

    private async Task LoadDocument(Guid id)
    {
        if (!_authReady || !AuthState.IsAuthenticated)
        {
            _pendingDocumentId = id;
            return;
        }

        _loading = true;
        _notFound = false;
        _document = null;

        try
        {
            var client = ApiClient.CreateClient();
            var response = await client.GetAsync($"/api/documents/{id}");

            if (response.IsSuccessStatusCode)
            {
                _document = await response.Content.ReadFromJsonAsync<GetDocumentResponse>();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                _notFound = true;
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Error: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task GenerateResume()
    {
        if (!_authReady || !AuthState.IsAuthenticated)
            return;

        if (_document is null) return;

        _generatingResume = true;

        try
        {
            var client = ApiClient.CreateClient();
            var response = await client.PostAsync($"/api/documents/{_document.Id}/generate-resume", null);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<GenerateResumeResponse>();
                Snackbar.Add($"Summary generated! ({result?.ChunksProcessed} chunks processed)", Severity.Success);
                await LoadDocument(_document.Id);
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Generation error: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _generatingResume = false;
        }
    }

    private async Task DownloadDocument()
    {
        if (_document is null) return;

        _downloading = true;

        try
        {
            var client = ApiClient.CreateClient();
            var response = await client.GetAsync($"/api/documents/{_document.Id}/download");

            if (response.IsSuccessStatusCode)
            {
                var bytes = await response.Content.ReadAsByteArrayAsync();
                var fileName = _document.FileName;
                var contentType = _document.ContentType;

                await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, contentType, bytes);
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                Snackbar.Add("Document not found.", Severity.Warning);
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Forbidden)
            {
                Snackbar.Add("You do not have permission to download this document.", Severity.Error);
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Error downloading document: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _downloading = false;
        }
    }

    private async Task ConfirmDeleteDocument()
    {
        if (_document is null) return;

        var parameters = new DialogParameters<MudMessageBox>
        {
            { x => x.Message, $"Are you sure you want to permanently delete \"{_document.FileName}\"? This action cannot be undone and the file will be removed forever." },
            { x => x.YesText, "Delete permanently" },
            { x => x.CancelText, "Cancel" }
        };

        var options = new DialogOptions { CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<MudMessageBox>("⚠️ Delete Document", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
            await DeleteDocument(_document.Id);
    }

    private async Task DeleteDocument(Guid id)
    {
        _deleting = true;

        try
        {
            var client = ApiClient.CreateClient();
            var response = await client.DeleteAsync($"/api/documents/{id}");

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Document deleted successfully.", Severity.Success);
                Navigation.NavigateTo("/profile");
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                Snackbar.Add("Document not found.", Severity.Warning);
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Forbidden)
            {
                Snackbar.Add("You do not have permission to delete this document.", Severity.Error);
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Error deleting document: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _deleting = false;
        }
    }

    private static string FormatFileSize(long bytes)
    {
        string[] sizes = ["B", "KB", "MB", "GB"];
        var order = 0;
        double size = bytes;
        while (size >= 1024 && order < sizes.Length - 1)
        {
            order++;
            size /= 1024;
        }
        return $"{size:0.##} {sizes[order]}";
    }
}
