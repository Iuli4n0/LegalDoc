@page "/upload"
@rendermode InteractiveServer
@using LegalDoc.Frontend.Models
@using LegalDoc.Frontend.Services
@inject ApiClient ApiClient
@inject ISnackbar Snackbar
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Upload Document</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Upload Document</MudText>

<MudCard Class="mb-4">
    <MudCardContent>
        <MudFileUpload T="IBrowserFile" 
                       Accept=".pdf,.doc,.docx,.txt" 
                       MaximumFileCount="1"
                       FilesChanged="OnFileSelected">
            <ActivatorContent>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.AttachFile">
                    Selectează Fișier
                </MudButton>
            </ActivatorContent>
        </MudFileUpload>

        @if (_selectedFile is not null)
        {
            <MudAlert Severity="Severity.Info" Class="mt-3">
                <strong>Fișier selectat:</strong> @_selectedFile.Name (@FormatFileSize(_selectedFile.Size))
            </MudAlert>
        }
    </MudCardContent>
    <MudCardActions>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@(_selectedFile is null || _uploading)"
                   OnClick="UploadFile"
                   StartIcon="@Icons.Material.Filled.CloudUpload">
            @if (_uploading)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                <MudText Class="ms-2">Se încarcă...</MudText>
            }
            else
            {
                <MudText>Încarcă Document</MudText>
            }
        </MudButton>
    </MudCardActions>
</MudCard>

@if (_uploadResult is not null)
{
    <MudAlert Severity="Severity.Success" Class="mb-4">
        Documentul a fost încărcat cu succes!
    </MudAlert>

    <MudCard>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">Detalii Document</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudSimpleTable Dense="true" Hover="true">
                <tbody>
                    <tr><td><strong>ID</strong></td><td>@_uploadResult.Id</td></tr>
                    <tr><td><strong>Nume Fișier</strong></td><td>@_uploadResult.FileName</td></tr>
                    <tr><td><strong>Tip Conținut</strong></td><td>@_uploadResult.ContentType</td></tr>
                    <tr><td><strong>Dimensiune</strong></td><td>@FormatFileSize(_uploadResult.FileSize)</td></tr>
                    <tr><td><strong>Data Upload</strong></td><td>@_uploadResult.UploadedAt.ToString("dd.MM.yyyy HH:mm")</td></tr>
                </tbody>
            </MudSimpleTable>
        </MudCardContent>
        <MudCardActions>
            <MudButton Variant="Variant.Text" Color="Color.Primary"
                       Href="@($"/documents/{_uploadResult.Id}")">
                Vezi Detalii Document
            </MudButton>
        </MudCardActions>
    </MudCard>
}

@code {
    private IBrowserFile? _selectedFile;
    private bool _uploading;
    private UploadDocumentResponse? _uploadResult;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var isAuthenticated = await AuthService.IsAuthenticatedAsync();
            if (!isAuthenticated)
            {
                Navigation.NavigateTo("/login", forceLoad: false);
            }
        }
    }

    private void OnFileSelected(IBrowserFile? file)
    {
        _selectedFile = file;
        _uploadResult = null;
    }

    private async Task UploadFile()
    {
        if (_selectedFile is null) return;

        _uploading = true;

        try
        {
            var client = ApiClient.CreateClient();

            using var content = new MultipartFormDataContent();
            var stream = _selectedFile.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024); // 50MB
            var streamContent = new StreamContent(stream);
            streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(_selectedFile.ContentType);
            content.Add(streamContent, "file", _selectedFile.Name);

            var response = await client.PostAsync("/api/documents/upload", content);

            if (response.IsSuccessStatusCode)
            {
                _uploadResult = await response.Content.ReadFromJsonAsync<UploadDocumentResponse>();
                Snackbar.Add("Document încărcat cu succes!", Severity.Success);
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Eroare la upload: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Eroare: {ex.Message}", Severity.Error);
        }
        finally
        {
            _uploading = false;
        }
    }

    private static string FormatFileSize(long bytes)
    {
        string[] sizes = ["B", "KB", "MB", "GB"];
        var order = 0;
        double size = bytes;
        while (size >= 1024 && order < sizes.Length - 1)
        {
            order++;
            size /= 1024;
        }
        return $"{size:0.##} {sizes[order]}";
    }
}

