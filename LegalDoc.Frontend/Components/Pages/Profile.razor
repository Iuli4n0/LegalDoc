@page "/profile"
@rendermode InteractiveServer
@using LegalDoc.Frontend.Models
@using LegalDoc.Frontend.Services
@inject ApiClient ApiClient
@inject AuthService AuthService
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS

<PageTitle>My Profile – Documents</PageTitle>

@if (!_authReady)
{
    <MudPaper Class="pa-4" Elevation="0">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Class="mr-2"/>
        <MudText Typo="Typo.body1">Initializing session...</MudText>
    </MudPaper>
}
else
{
    <MudText Typo="Typo.h4" GutterBottom="true">
        <MudIcon Icon="@Icons.Material.Filled.Person" Class="mr-2"/>
        My Profile
    </MudText>

    @if (AuthState.IsAuthenticated)
    {
        <MudPaper Class="pa-4 mb-4" Elevation="1">
            <MudGrid AlignItems="Center">
                <MudItem xs="12" sm="8">
                    <MudText Typo="Typo.h6">@AuthState.UserName</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@AuthState.UserEmail</MudText>
                </MudItem>
            </MudGrid>
        </MudPaper>
    }

    <MudText Typo="Typo.h5" GutterBottom="true" Class="mt-2">
        <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Class="mr-2"/>
        My Documents
    </MudText>

    <MudTable ServerData="LoadServerData"
              Dense="false"
              Hover="true"
              Striped="false"
              Bordered="false"
              @ref="_table"
              RowsPerPage="10"
              Class="profile-doc-table">
        <ToolBarContent>
            <MudSpacer/>
            <MudTooltip Text="Refresh">
                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                               OnClick="ReloadTable"
                               Color="Color.Default"/>
            </MudTooltip>
        </ToolBarContent>
        <HeaderContent>
            <MudTh Style="width:35%">
                <MudTableSortLabel SortLabel="FileName" T="GetDocumentResponse">File Name</MudTableSortLabel>
            </MudTh>
            <MudTh Style="width:13%">
                <MudTableSortLabel SortLabel="ContentType" T="GetDocumentResponse">Type</MudTableSortLabel>
            </MudTh>
            <MudTh Style="width:7%">
                <MudTableSortLabel SortLabel="FileSize" T="GetDocumentResponse">Size</MudTableSortLabel>
            </MudTh>
            <MudTh Style="width:12%">
                <MudTableSortLabel SortLabel="UploadedAt" T="GetDocumentResponse" InitialDirection="SortDirection.Descending">Upload Date</MudTableSortLabel>
            </MudTh>
            <MudTh Style="width:33%">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="File Name" Style="max-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" Class="mr-1"/>
                @context.FileName
            </MudTd>
            <MudTd DataLabel="Type">@context.ContentType</MudTd>
            <MudTd DataLabel="Size">@FormatFileSize(context.FileSize)</MudTd>
            <MudTd DataLabel="Upload Date">@context.UploadedAt.ToString("dd.MM.yyyy HH:mm")</MudTd>
            <MudTd DataLabel="Actions">
                <div style="display:flex;flex-wrap:nowrap;gap:6px;align-items:center">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Visibility"
                               Href="@($"/documents/{context.Id}")">
                        Details
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Info"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Download"
                               Disabled="@(_downloadingId == context.Id)"
                               OnClick="@(() => DownloadDocument(context))">
                        @if (_downloadingId == context.Id)
                        {
                            <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                            <MudText Class="ms-2">Downloading...</MudText>
                        }
                        else
                        {
                            <MudText>Download</MudText>
                        }
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Error"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.DeleteForever"
                               OnClick="@(() => ConfirmDeleteDocument(context))">
                        Delete
                    </MudButton>
                </div>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4" Color="Color.Secondary">
                <MudIcon Icon="@Icons.Material.Filled.Inbox" Class="mr-2"/>
                You haven't uploaded any documents yet.
                <MudLink Href="/upload" Class="ml-1">Upload your first document</MudLink>
            </MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText Class="pa-4">Loading documents...</MudText>
        </LoadingContent>
        <PagerContent>
            <MudTablePager RowsPerPageString="Rows per page:"
                           PageSizeOptions="new[] { 10, 25, 50 }"/>
        </PagerContent>
    </MudTable>
}

@code {
    private MudTable<GetDocumentResponse>? _table;
    private bool _authReady;
    private Guid? _downloadingId;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login", forceLoad: false);
            return;
        }

        _authReady = true;
        StateHasChanged();
    }

    private async Task<TableData<GetDocumentResponse>> LoadServerData(TableState state, CancellationToken ct)
    {
        if (!_authReady || !AuthState.IsAuthenticated)
            return new TableData<GetDocumentResponse> { Items = [], TotalItems = 0 };

        try
        {
            var sortBy = string.IsNullOrEmpty(state.SortLabel) ? "UploadedAt" : state.SortLabel;
            var ascending = state.SortDirection == SortDirection.Ascending;
            var page = state.Page + 1;
            var pageSize = state.PageSize;

            var url = $"/api/documents?page={page}&pageSize={pageSize}&sortBy={sortBy}&ascending={ascending}";

            var client = ApiClient.CreateClient();
            var result = await client.GetFromJsonAsync<GetUserDocumentsResponse>(url, ct);

            if (result is null)
                return new TableData<GetDocumentResponse> { Items = [], TotalItems = 0 };

            return new TableData<GetDocumentResponse>
            {
                Items = result.Items,
                TotalItems = result.TotalCount
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading documents: {ex.Message}", Severity.Error);
            return new TableData<GetDocumentResponse> { Items = [], TotalItems = 0 };
        }
    }

    private async Task DownloadDocument(GetDocumentResponse document)
    {
        _downloadingId = document.Id;

        try
        {
            var client = ApiClient.CreateClient();
            var response = await client.GetAsync($"/api/documents/{document.Id}/download");

            if (response.IsSuccessStatusCode)
            {
                var bytes = await response.Content.ReadAsByteArrayAsync();
                await JS.InvokeVoidAsync("downloadFileFromBytes", document.FileName, document.ContentType, bytes);
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                Snackbar.Add("Document not found.", Severity.Warning);
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Forbidden)
            {
                Snackbar.Add("You do not have permission to download this document.", Severity.Error);
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Error downloading document: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _downloadingId = null;
        }
    }

    private async Task ConfirmDeleteDocument(GetDocumentResponse document)
    {
        var parameters = new DialogParameters<MudMessageBox>
        {
            { x => x.Message, $"Are you sure you want to permanently delete \"{document.FileName}\"? This action cannot be undone and the file will be removed forever." },
            { x => x.YesText, "Delete permanently" },
            { x => x.CancelText, "Cancel" }
        };

        var options = new DialogOptions { CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<MudMessageBox>("⚠️ Delete Document", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
            await DeleteDocument(document.Id);
    }

    private async Task DeleteDocument(Guid id)
    {
        try
        {
            var client = ApiClient.CreateClient();
            var response = await client.DeleteAsync($"/api/documents/{id}");

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Document deleted successfully.", Severity.Success);
                await ReloadTable();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                Snackbar.Add("Document not found.", Severity.Warning);
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Forbidden)
            {
                Snackbar.Add("You do not have permission to delete this document.", Severity.Error);
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Error deleting document: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task ReloadTable()
    {
        if (_table is not null)
            await _table.ReloadServerData();
    }

    private static string FormatFileSize(long bytes)
    {
        string[] sizes = ["B", "KB", "MB", "GB"];
        var order = 0;
        double size = bytes;
        while (size >= 1024 && order < sizes.Length - 1)
        {
            order++;
            size /= 1024;
        }
        return $"{size:0.##} {sizes[order]}";
    }
}
