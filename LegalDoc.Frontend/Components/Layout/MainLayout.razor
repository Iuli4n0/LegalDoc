@inherits LayoutComponentBase
@using LegalDoc.Frontend.Services
@inject AuthService AuthService
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@implements IDisposable

<MudThemeProvider Theme="_theme" IsDarkMode="true"/>
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<MudLayout>
    <MudAppBar Elevation="0" Dense="true" Style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); border-bottom: 1px solid rgba(255,255,255,0.06);">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer"/>
        <MudText Typo="Typo.h6" Class="ml-3" Style="font-weight: 700; letter-spacing: 0.5px;">
            <MudIcon Icon="@Icons.Material.Filled.Gavel" Class="mr-2" Style="vertical-align: middle;"/>LegalDoc
        </MudText>
        <MudSpacer/>
        @if (AuthState.IsAuthenticated)
        {
            <MudButton Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.AccountCircle" Href="/profile"
                       Style="text-transform: none; font-weight: 500;">
                @AuthState.UserName
            </MudButton>
            <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit" OnClick="HandleLogout" Title="Sign out"/>
        }
        else
        {
            <MudButton Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Login" Href="/login">
                Sign In
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.PersonAdd" Href="/register" Class="ml-2">
                Register
            </MudButton>
        }
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="0" ClipMode="DrawerClipMode.Always"
               Style="background: #0f1123; border-right: 1px solid rgba(255,255,255,0.06);">
        <MudNavMenu Color="Color.Primary" Bordered="true" Class="mt-2">
            @if (AuthState.IsAuthenticated)
            {
                <MudNavLink Href="/upload" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.CloudUpload">Upload Document</MudNavLink>
                <MudNavLink Href="/documents" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.FindInPage">Search Document</MudNavLink>
            }
            else
            {
                <MudNavLink Href="/login" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Login">Sign In</MudNavLink>
                <MudNavLink Href="/register" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.PersonAdd">Register</MudNavLink>
            }
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="pt-16 px-4" Style="background: #0d1117; min-height: 100vh;">
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;

    private readonly MudTheme _theme = new()
    {
        PaletteDark = new PaletteDark
        {
            Primary = "#5C6BC0",
            PrimaryDarken = "#3949AB",
            PrimaryLighten = "#7986CB",
            Secondary = "#26A69A",
            SecondaryDarken = "#00897B",
            SecondaryLighten = "#4DB6AC",
            Tertiary = "#AB47BC",
            Info = "#42A5F5",
            Success = "#66BB6A",
            Warning = "#FFA726",
            Error = "#EF5350",
            Background = "#0d1117",
            Surface = "#161b22",
            DrawerBackground = "#0f1123",
            AppbarBackground = "#1a1a2e",
            AppbarText = "#e6edf3",
            TextPrimary = "#e6edf3",
            TextSecondary = "#8b949e",
            ActionDefault = "#8b949e",
            ActionDisabled = "rgba(139,148,158,0.3)",
            ActionDisabledBackground = "rgba(139,148,158,0.12)",
            Divider = "rgba(255,255,255,0.06)",
            DividerLight = "rgba(255,255,255,0.03)",
            TableLines = "rgba(255,255,255,0.06)",
            LinesDefault = "rgba(255,255,255,0.06)",
            HoverOpacity = 0.06,
            Black = "#0d1117",
            White = "#ffffff"
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "8px",
            DrawerWidthLeft = "240px"
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = ["Inter", "Roboto", "Helvetica", "Arial", "sans-serif"],
                FontSize = "0.875rem",
                FontWeight = "400",
                LineHeight = "1.5",
                LetterSpacing = "0.00938em"
            },
            H4 = new H4Typography
            {
                FontWeight = "700",
                FontSize = "1.75rem"
            },
            H5 = new H5Typography
            {
                FontWeight = "600",
                FontSize = "1.35rem"
            },
            H6 = new H6Typography
            {
                FontWeight = "600",
                FontSize = "1.1rem"
            }
        }
    };

    protected override void OnInitialized()
    {
        AuthState.OnChange += HandleAuthStateChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
    }

    private void HandleAuthStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        Snackbar.Add("Signed out successfully.", Severity.Info);
        Navigation.NavigateTo("/login", forceLoad: false);
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    public void Dispose()
    {
        AuthState.OnChange -= HandleAuthStateChanged;
    }
}
